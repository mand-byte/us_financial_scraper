# ClickHouse connection used by the scraper container.
# If the ClickHouse container publishes 8123 on the Synology host, keep host.docker.internal.
# Otherwise set this to the ClickHouse container name on the same Docker network, or to the NAS IP.
CLICKHOST_HOST=host.docker.internal
CLICKHOST_PORT=8123
CLICKHOST_DATABASE=quant_data
CLICKHOST_USERNAME=default
CLICKHOST_PASSWORD=

# Required API keys
MASSIVE_API_KEY=replace_me

# Optional but recommended
OPENFIGI_API_KEY=
SEC_API_IO_KEY=
SEC_DOWNLOADER_COMPANY=QuantResearch
SEC_DOWNLOADER_EMAIL=research@example.com

# Scraper behavior
SCRAPING_START_DATE=2014-01-01
KLINE_SPAN=1
CONSOLE_LOG_LEVEL=INFO
FILE_LOG_LEVEL=DEBUG
